# Core server
SERVER_ADDR=:8080
DATABASE_DRIVER=sqlite
DATABASE_URL=utexo_lsp.db

# Upstream node APIs
LSP_BASE_URL=http://127.0.0.1:3001
LSP_TOKEN=
RGB_NODE_BASE_URL=http://127.0.0.1:3001
RGB_NODE_TOKEN=
HTTP_TIMEOUT=15s
CRON_EVERY=30s

# Invoice / transfer policy
SENDRGB_FEE_RATE=1
MIN_CONFIRMATIONS=1
EXPIRY_MATCH_TOLERANCE_SEC=5
MIN_AMT_MSAT=3000000
DEFAULT_RGB_ASSIGNMENT=Any

# Lightning Address
LIGHTNING_ADDRESS_DOMAIN_URL=http://127.0.0.1:8080
LIGHTNING_ADDRESS_SHORT_DESCRIPTION=Payment to utexo-lsp
LIGHTNING_ADDRESS_MIN_SENDABLE_MSAT=3000000
LIGHTNING_ADDRESS_MAX_SENDABLE_MSAT=3000000

# Async payments (APay)
APAY_BEARER_TOKEN=
APAY_INBOUND_INVOICE_EXPIRY=3600s
APAY_OUTBOUND_INVOICE_EXPIRY=900s
APAY_INBOUND_MIN_FINAL_CLTV_EXPIRY_DELTA=144
APAY_OUTBOUND_MIN_FINAL_CLTV_EXPIRY_DELTA=42
APAY_CLAIM_MARGIN_BLOCKS=12
APAY_REQUEST_OUTBOUND_INVOICE_PATH=/apay/outboundinvoice

# LSP route overrides
LSP_OPENCONNECTION_PATH=/connectpeer
LSP_GET_INFO_PATH=/nodeinfo
LSP_LISTCONNECTIONS_PATH=/listpeers
LSP_LISTCHANNELS_PATH=/listchannels
LSP_OPENCHANNEL_PATH=/openchannel
LSP_LNINVOICE_PATH=/lninvoice
LSP_INVOICESTATUS_PATH=/invoicestatus
LSP_CANCELLNINVOICE_PATH=
LSP_SENDRGB_PATH=/sendrgb
LSP_SENDLN_PATH=/sendpayment

# RGB route overrides
RGB_DECODE_LN_PATH=/decodelninvoice
RGB_DECODE_RGB_PATH=/decodergbinvoice
RGB_INVOICE_PATH=/rgbinvoice
RGB_REFRESH_TRANSFERS_PATH=/refreshtransfers
RGB_LIST_TRANSFERS_PATH=/listtransfers
RGB_LIST_UNSPENTS_PATH=/listunspents
RGB_CREATE_UTXOS_PATH=/createutxos
BLOCK_HEIGHT_INFO_PATH=/networkinfo

# Channel / asset policy
DEFAULT_CHANNEL_CAPACITY_SAT=200000
DEFAULT_CHANNEL_ASSET_AMOUNT=1
DEFAULT_CHANNEL_PUSH_MSAT=0
# Comma-separated allowlist, for example: assetA,assetB
SUPPORTED_ASSET_IDS=
DEFAULT_VIRTUAL_OPEN_MODE=

# UTXO maintenance
UTXO_MIN_COUNT=0
UTXO_TARGET_COUNT=0
UTXO_SIZE_SAT=32000
UTXO_FEE_RATE=1
UTXO_SKIP_SYNC=false
